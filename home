<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LXUN / 寻</title>
    <style>
        /* 基础样式复位 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #ffffff;
            color: #000000;
            font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            line-height: 1.1;
            padding: 4vw;
        }

        /* 核心布局 */
        main {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* 左侧：品牌与定义 */
        .hero {
            position: sticky;
            top: 4vw;
            height: fit-content;
        }

        .title {
            font-size: clamp(5rem, 15vw, 12rem);
            font-weight: 900;
            letter-spacing: -0.05em;
            text-transform: uppercase;
            line-height: 0.8;
            margin-bottom: 2rem;
        }

        .definition {
            font-size: 1.5rem;
            max-width: 300px;
            border-top: 5px solid #000;
            padding-top: 1rem;
        }

        /* 右侧：内容与链接 */
        .content {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding-top: 20vh;
        }

        .nav-links {
            list-style: none;
            margin-bottom: 10rem;
        }

        .nav-links li {
            border-bottom: 2px solid #000;
        }

        .nav-links a {
            display: block;
            font-size: clamp(2rem, 5vw, 4rem);
            font-weight: 700;
            text-decoration: none;
            color: #000;
            padding: 1.5rem 0;
            transition: all 0.2s ease;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* 悬停反色效果 */
        .nav-links a:hover {
            background-color: #000;
            color: #fff;
            padding-left: 1rem;
        }

        .nav-links a::after {
            content: "→";
            font-size: 2rem;
        }

        /* 页脚 */
        footer {
            margin-top: 5rem;
            font-size: 1rem;
            font-weight: 500;
            text-transform: uppercase;
        }

        /* 移动端适配 */
        @media (max-width: 768px) {
            main {
                grid-template-columns: 1fr;
            }
            .content {
                padding-top: 2rem;
            }
            .title {
                font-size: 20vw;
            }
        }
    </style>
</head>
<body>

    <main>
        <section class="hero">
            <h1 class="title">LXUN<br>寻</h1>
            <p class="definition">
                寻找技术的边界，<br>
                记录逻辑的演进。
            </p>
        </section>

        <section class="content">
            <ul class="nav-links">
                <li><a href="https://github.com/你的用户名" target="_blank">GITHUB</a></li>
                <li><a href="/blog">ARCHIVE</a></li>
                <li><a href="/projects">PROJECTS</a></li>
                <li><a href="/about">ABOUT</a></li>
            </ul>

            <footer>
                © 2026 LXUN.ORG / ESTABLISHED IN LOGIC
            </footer>
        </section>
    </main>

</body>
</html>
