---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post-article">
    <div class="post-header">
      <div class="post-meta-top">
        <a href="/" class="back-link">← Back</a>
        <span class="post-date-large">
          {post.data.date.toLocaleDateString("zh-CN", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </span>
      </div>
      <h1 class="post-title-large">{post.data.title}</h1>
      <div class="post-tags">
        {post.data.tags?.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>
    <hr class="thin" />
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post-article {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 40px 80px;
  }
  .post-header {
    margin-bottom: 32px;
  }
  .post-meta-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }
  .back-link {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-dark);
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--black);
  }
  .post-date-large {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--gray-dark);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .post-title-large {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(36px, 5vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-dark);
    border: var(--rule) solid var(--gray-mid);
    padding: 3px 8px;
  }

  /* ── Article content ── */
  .post-content {
    padding-top: 32px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.9;
    color: var(--black);
  }
  .post-content h1,
  .post-content h2,
  .post-content h3 {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-top: 1.6em;
    margin-bottom: 0.6em;
  }
  .post-content h1 { font-size: 24px; }
  .post-content h2 { font-size: 18px; border-bottom: var(--rule) solid var(--black); padding-bottom: 8px; }
  .post-content h3 { font-size: 15px; }
  .post-content p { margin-bottom: 1.2em; }
  .post-content strong { font-weight: 500; }
  .post-content em { font-style: normal; color: var(--gray-dark); }
  .post-content ul,
  .post-content ol { margin: 1em 0; padding-left: 24px; }
  .post-content li { margin-bottom: 0.4em; }
  .post-content code {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--gray-light);
    padding: 1px 5px;
    border: var(--rule) solid var(--gray-mid);
    border-radius: 2px;
  }
  .post-content pre {
    margin: 1.2em 0;
    padding: 16px 18px;
    background: var(--gray-light);
    border: var(--rule) solid var(--gray-mid);
    border-radius: 2px;
    overflow-x: auto;
  }
  .post-content pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 11.5px;
    line-height: 1.7;
  }
  .post-content blockquote {
    margin: 1.2em 0;
    padding: 12px 16px;
    border-left: 3px solid var(--black);
    background: var(--gray-light);
    font-style: normal;
  }
  .post-content a {
    color: var(--black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .post-content a:hover {
    background: var(--black);
    color: var(--white);
  }
  .post-content hr {
    border: none;
    border-top: var(--rule) dashed var(--gray-mid);
    margin: 2em 0;
  }
</style>
