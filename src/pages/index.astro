---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="lxun.org" description="Tech notes, guides, and explorations">
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-label">
        <span class="label-index" aria-hidden="true">01</span>
        <div class="label-tag">Personal Site<br />lxun.org</div>
      </div>
      <div class="hero-main">
        <h1 class="hero-name">LXUN</h1>
        <p class="hero-desc">
          Tech notes, guides, and explorations.<br />
          Building things, solving problems,<br />
          and writing down what I learn.
        </p>
      </div>
      <div class="hero-meta">
        <div class="meta-item">
          <strong>Domain</strong>
          lxun.org
        </div>
        <div class="meta-item">
          <strong>Focus</strong>
          Infrastructure · DevOps<br />Cloud · Self-hosting
        </div>
        <div class="meta-item">
          <strong>Status</strong>
          Actively Writing
        </div>
      </div>
    </div>
  </section>

  <section id="posts">
    <div class="container">
      <div class="section-header">
        <span class="section-num">02</span>
        <span class="section-title">Posts</span>
        <span class="section-count">{posts.length} articles</span>
      </div>
    </div>
    <div class="posts-grid">
      {
        posts.map((post, i) => (
          <article class="post-card col-6">
            <a href={`/posts/${post.slug}/`} class="post-link">
              <span class="post-num" aria-hidden="true"
                >{String(i + 1).padStart(2, "0")}</span
              >
              <span class="post-tag">{post.data.tags?.[0] || "Article"}</span>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-excerpt">{post.data.description}</p>
              <div class="post-footer">
                <span class="post-date">
                  {post.data.date.toLocaleDateString("zh-CN", {
                    year: "numeric",
                    month: "2-digit",
                    day: "2-digit",
                  })}
                </span>
                <span class="post-arrow">→</span>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    border-bottom: 4px solid var(--black);
    position: relative;
    overflow: hidden;
    min-height: 480px;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--grid-gap);
    padding: 0 40px;
    max-width: 1280px;
    margin: 0 auto;
    min-height: 480px;
    align-items: end;
  }
  .hero-label {
    grid-column: 1 / 3;
    padding-bottom: 52px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 6px;
  }
  .label-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray-dark);
    border-left: 3px solid var(--black);
    padding-left: 10px;
    line-height: 1.4;
  }
  .label-index {
    font-family: var(--font-display);
    font-size: 120px;
    font-weight: 900;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--gray-mid);
    display: block;
  }
  .hero-main {
    grid-column: 3 / 11;
    padding: 80px 0 52px;
    border-left: var(--rule) solid var(--black);
    border-right: var(--rule) solid var(--black);
    padding-left: 32px;
    padding-right: 32px;
  }
  .hero-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(80px, 10vw, 148px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .hero-desc {
    max-width: 480px;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.8;
    color: var(--gray-dark);
    border-top: var(--rule) solid var(--black);
    padding-top: 20px;
    margin-top: 0;
  }
  .hero-meta {
    grid-column: 11 / 13;
    padding-bottom: 52px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 20px;
  }
  .meta-item {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-dark);
    line-height: 1.7;
  }
  .meta-item strong {
    display: block;
    color: var(--black);
    font-weight: 500;
    font-size: 11px;
    margin-bottom: 3px;
  }

  /* ── SECTION HEADER ── */
  #posts {
    padding-bottom: 80px;
    border-bottom: 4px solid var(--black);
  }
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    padding: 28px 0;
    border-bottom: var(--rule) solid var(--black);
    margin-bottom: 0;
  }
  .section-num {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--gray-dark);
  }
  .section-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .section-count {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--gray-dark);
    letter-spacing: 0.1em;
  }

  /* ── POSTS GRID ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0;
  }
  .post-card {
    grid-column: span 6;
    border-right: var(--rule) solid var(--black);
    border-bottom: var(--rule) solid var(--black);
    position: relative;
    transition: background 0.2s;
  }
  .post-card:nth-child(2n) {
    border-right: none;
  }
  .post-card:hover {
    background: var(--black);
  }
  .post-card:hover * {
    color: var(--white) !important;
  }
  .post-card:hover .post-tag {
    border-color: var(--white);
  }
  .post-card:hover .post-num {
    -webkit-text-stroke-color: rgba(255, 255, 255, 0.12);
  }
  .post-card:hover .post-arrow {
    opacity: 1;
  }

  .post-link {
    display: block;
    padding: 28px 28px 24px;
    text-decoration: none;
    color: inherit;
  }

  .post-num {
    font-family: var(--font-display);
    font-size: 96px;
    font-weight: 900;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px var(--gray-mid);
    display: block;
    margin-bottom: -8px;
    transition: -webkit-text-stroke-color 0.2s;
  }
  .post-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gray-dark);
    border: var(--rule) solid var(--black);
    padding: 3px 8px;
    margin-bottom: 14px;
    transition: border-color 0.2s, color 0.2s;
  }
  .post-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--black);
    margin-bottom: 10px;
    transition: color 0.2s;
  }
  .post-excerpt {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.7;
    color: var(--gray-dark);
    transition: color 0.2s;
  }
  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 20px;
    padding-top: 12px;
    border-top: var(--rule) solid var(--black);
    transition: border-color 0.2s;
  }
  .post-date {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--gray-dark);
    transition: color 0.2s;
  }
  .post-arrow {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    opacity: 0;
    transition: opacity 0.2s;
  }

  @media (max-width: 768px) {
    .post-card {
      grid-column: span 12;
    }
    .post-card:nth-child(2n) {
      border-right: none;
    }
  }
</style>
